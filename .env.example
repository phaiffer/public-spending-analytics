# Local environment settings for future scripts.
# Copy to .env if needed. Do not commit real secrets or personal paths.

GOV_SPENDING_CONFIG_PATH=config/project.toml
GOV_SPENDING_DUCKDB_PATH=data/curated/gov_spending.duckdb

# Required for official Portal da Transparencia API ingestion.
# Register for a token at:
# https://portaldatransparencia.gov.br/api-de-dados/cadastrar-email
PORTAL_TRANSPARENCIA_API_KEY=replace-with-your-api-key
